<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:c="/lib/credentials" xmlns:f="/lib/form">
    <f:entry>
        <f:repeatableHeteroProperty field="credentialsIds" honorOrder="true" hasHeader="true">
            <f:entry title="${%Credentials}">
                <c:select/>
            </f:entry>
         </f:repeatableHeteroProperty>
    </f:entry>
</j:jelly>
